<section class="page-section">
  <div class="container container-narrow">
    <div class="section-heading">
      <p class="eyebrow">Registro</p>
      <h2>{{titulo}}</h2>
      <p class="section-text">
        Crea tu cuenta para publicar eventos y participar en la comunidad.
      </p>
    </div>

    <form id="registerForm" class="card form-card">
      <div class="form-grid">
        <div class="form-group full">
          <label for="fullname">Nombre completo</label>
          <input type="text" id="fullname" name="fullname" required />
        </div>

        <div class="form-group full">
          <label for="username">Nombre de usuario</label>
          <input type="text" id="username" name="username" required />
        </div>

        <div class="form-group full">
          <label for="email">Correo electrónico</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group full">
          <label for="password">Contraseña</label>
          <input type="password" id="password" name="password" required />
        </div>

        <div class="form-group full">
          <label for="city">Ciudad</label>
          <input type="text" id="city" name="city" />
        </div>
      </div>

      <div class="actions mt-3">
        <button type="submit" class="btn">Crear cuenta</button>
        <a href="/auth/login" class="btn btn-light">Ya tengo cuenta</a>
      </div>

      <p id="formMessage" class="form-message"></p>
    </form>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("registerForm");
    const message = document.getElementById("formMessage");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      message.textContent = "";
      message.className = "form-message";

      const payload = {
        fullname: form.fullname.value.trim(),
        username: form.username.value.trim(),
        email: form.email.value.trim(),
        password: form.password.value,
        city: form.city.value.trim() || null,
      };

      try {
        const response = await fetch("/auth/register", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          credentials: "same-origin",
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (!response.ok) {
          message.textContent = result.message || "No se pudo completar el registro";
          message.className = "form-message error";
          return;
        }

        message.textContent = result.message || "Usuario registrado correctamente";
        message.className = "form-message success";
        form.reset();

        setTimeout(() => {
          window.location.href = "/auth/login";
        }, 700);
      } catch (error) {
        message.textContent = "Error de red al registrar la cuenta";
        message.className = "form-message error";
      }
    });
  });
</script>