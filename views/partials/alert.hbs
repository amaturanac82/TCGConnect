{{#if success}}
  <div class="card" style="border-left: 4px solid #16a34a; margin-top: 1rem;">
    <p style="color:#166534; margin-bottom:0;"><strong>Éxito:</strong> {{success}}</p>
  </div>
{{/if}}

{{#if message}}
  <div class="card" style="border-left: 4px solid #2563eb; margin-top: 1rem;">
    <p style="color:#1d4ed8; margin-bottom:0;"><strong>Información:</strong> {{message}}</p>
  </div>
{{/if}}

{{#if warning}}
  <div class="card" style="border-left: 4px solid #d97706; margin-top: 1rem;">
    <p style="color:#92400e; margin-bottom:0;"><strong>Atención:</strong> {{warning}}</p>
  </div>
{{/if}}

{{#if error}}
  <div class="card" style="border-left: 4px solid #dc2626; margin-top: 1rem;">
    <p style="color:#991b1b; margin-bottom:0;"><strong>Error:</strong> {{error}}</p>
  </div>
{{/if}}

{{#if errors.length}}
  <div class="card" style="border-left: 4px solid #dc2626; margin-top: 1rem;">
    <p style="color:#991b1b;"><strong>Revisa lo siguiente:</strong></p>
    <ul>
      {{#each errors}}
        <li>{{this.msg}}</li>
      {{/each}}
    </ul>
  </div>
{{/if}}